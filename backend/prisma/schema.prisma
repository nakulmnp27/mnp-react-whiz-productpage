generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id          BigInt   @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String   @db.VarChar
  benefitsMessage     String @db.VarChar(500)
  

  rating      Float?
  learners    BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examDetails CourseExamDetail[]
  pricing      Pricing[]
  features     CourseFeature[]
  stats        CourseStat[]
  faqs         Faq[]
  testimonials Testimonial[]
  examInfo     ExamInfo[]
  eligibility  EligibilityPoint[]
  courseOverview  CourseOverview[]
  courseBenefits   CourseBenefit[]
  examFeatureCards ExamFeatureCard[]
}

model Pricing {
  id           BigInt @id @default(autoincrement())
  title        String @db.VarChar(100)
  sellingPrice Float
  offerPrice    Float
  isticked     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt 
  course   Course @relation(fields: [courseId], references: [id])
}

model CourseFeature {
  id   BigInt @id @default(autoincrement())
  icon  String @db.VarChar(500)
  title String @db.VarChar(500)
  description   String   @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, title])
}

model CourseStat {
  id    BigInt @id @default(autoincrement())
  icon   String  @db.VarChar(255)
  label String @db.VarChar(100)
  value String @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])
}

model Faq {
  id       BigInt @id @default(autoincrement())
  question String @db.VarChar(500)
  answer   String @db.VarChar(2000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, question])
}

model Testimonial {
  id      BigInt @id @default(autoincrement())
  name    String @db.VarChar(150)
  role    String? @db.VarChar(150)
  message String @db.VarChar(1000)
  rating  Float
  profile  String @db.VarChar(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])
}

model ExamInfo {
  id       BigInt @id @default(autoincrement())
  icon  String @db.VarChar(100)
  heading String @db.VarChar(100)
  text String @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt 
  course   Course @relation(fields: [courseId], references: [id])
   @@unique([courseId, heading])
}

model EligibilityPoint {
  id   BigInt @id @default(autoincrement())
  heading  String  @db.VarChar(50)
  text String @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, text])
}

model CourseOverview {
  id        BigInt @id @default(autoincrement())
  text      String @db.VarChar(500)

  column    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId  BigInt
  course    Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, text])
}

model CourseBenefit {
  id          BigInt @id @default(autoincrement())

  title       String @db.VarChar(50)
  description String @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, title])
}

model CourseExamDetail {
  id          BigInt   @id @default(autoincrement())

  heading     String   @db.VarChar(100)
  description String   @db.VarChar(1000)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId    BigInt
  course      Course   @relation(fields: [courseId], references: [id])

  @@unique([courseId, heading])
}

model ExamFeatureCard {
  id   BigInt @id @default(autoincrement())

  icon String @db.VarChar(500)
  text String @db.VarChar(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, text])
}

