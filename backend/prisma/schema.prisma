generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id          BigInt   @id @default(autoincrement())
  title       String   @unique @db.VarChar
  description String   @db.VarChar
  benefitsMessage     String @db.VarChar
  

  rating      Float?
  learners    BigInt?

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examDetails CourseExamDetail[]
  pricing      Pricing[]
  features     CourseFeature[]
  stats        CourseStat[]
  faqs         Faq[]
  testimonials Testimonial[]
  examInfo     ExamInfo[]
//  eligibility  EligibilityPoint[]
  courseOverview  CourseOverview[]
  courseBenefits   CourseBenefit[]
  examFeatureCards ExamFeatureCard[]

   @@index([title])
   @@index([createdAt])
   @@index([isDeleted])
}

model Pricing {
  id           BigInt @id @default(autoincrement())
  title        String @db.VarChar
  sellingPrice Float
  offerPrice    Float
  isticked     Boolean @default(false)

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt 
  course   Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([isDeleted])
}

model CourseFeature {
  id   BigInt @id @default(autoincrement())
  icon  String @db.VarChar
  title String @db.VarChar
  description   String   @db.VarChar(200)

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, title])
  @@index([courseId])
  @@index([isDeleted])
}

model CourseStat {
  id    BigInt @id @default(autoincrement())
  icon   String  @db.VarChar
  label String @db.VarChar
  value String @db.VarChar

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([isDeleted])
}

model Faq {
  id       BigInt @id @default(autoincrement())
  question String @db.VarChar
  answer   String @db.VarChar

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, question])
  @@index([courseId])
  @@index([isDeleted])
}

model Testimonial {
  id      BigInt @id @default(autoincrement())
  name    String @db.VarChar
  role    String? @db.VarChar
  message String @db.VarChar
  rating  Float
  profile  String @db.VarChar

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt
  course   Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@index([isDeleted])
}

model ExamInfo {
  id       BigInt @id @default(autoincrement())
  icon  String @db.VarChar
  heading String @db.VarChar
  text String @db.VarChar

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseId BigInt 
  course   Course @relation(fields: [courseId], references: [id])
   @@unique([courseId, heading])
   @@index([courseId])
   @@index([isDeleted])
}

